# PostgreSQL for docker-compose
POSTGRES_DB=qora_db
POSTGRES_USER=qora_user
POSTGRES_PASSWORD=your_secure_password_here

# Django DATABASE_URL (must match the above)
DATABASE_URL=postgres://qora_user:your_secure_password_here@postgres:5432/qora_db

# Django settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Redis
REDIS_URL=redis://redis:6379/0

# MongoDB
MONGO_DB=qora_mongo
MONGO_URL=mongodb://mongodb_user:mongodb_password@mongodb:27017/
MONGO_INITDB_ROOT_USERNAME=mongodb_user
MONGO_INITDB_ROOT_PASSWORD=mongodb_password

# Neo4j
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_AUTH=neo4j/neo4j_password